import { myWeather } from "./database";
import { getWeatherData } from "./api";
import { main } from "./populateWeather.js";
import { populateSearchGif, populateWeatherData } from "./populateWeather.js";
import { showLoading, hideLoading } from "./loading.js";
const toggleTempView = document.getElementById("toggleTempView")


export async function instansiateHomePage(){
    let searchBox = document.getElementById('weather-search');
    let searchBtn = document.getElementById('weather-search-btn');
    instansiateToggleBtn();
    
    myWeather.length = 0;
    showLoading()
    try{
        myWeather.push(await getWeatherData("Kathmandu"))
        await populateWeatherData(myWeather[0],toggleTempView.checked )

    }catch(error){
        console.log(`Error while fetching weather:`, error)
    }finally{
        hideLoading()
    }
   
    searchBtn.addEventListener('click', async (event)=>{
        event.preventDefault()
        if(searchBox.value != ""){
            myWeather.length= 0;
            
            showLoading()
            try{
                let weatherCleanData = await getWeatherData(searchBox.value)
                myWeather.push(weatherCleanData)
                searchBox.value = "";
                let todayWeatherGif =  weatherCleanData.condition;
                populateWeatherData(myWeather[0],toggleTempView.checked )
                populateSearchGif(todayWeatherGif);
                console.log(weatherCleanData) 
            }catch(error){
                console.log(`Error while fetching weather:`, error)
            }finally{
                hideLoading()
            }
            
            
        }else{
            return
        }
        
    })
    
}

function instansiateToggleBtn(){
    toggleTempView.addEventListener('click', ()=>{
        if(myWeather.length!=0){
            populateWeatherData(myWeather[0], toggleTempView.checked)
        }


        
    })

}


export function showHome(){
    
    main.style.display = "grid"
}


export function hideHome(){
    main.style.display = "none"
}


            















